<?xml version="1.0" encoding="utf-8"?>
<resources>

    <attr name="plv_radius" format="dimension" />
    <attr name="plv_mode" format="flags">
        <flag name="none" value="0" />
        <flag name="leftTop" value="1" />
        <flag name="leftBottom" value="2" />
        <flag name="rightTop" value="4" />
        <flag name="rightBottom" value="8" />
        <flag name="left" value="3" />
        <flag name="top" value="5" />
        <flag name="bottom" value="10" />
        <flag name="right" value="12" />
        <flag name="all" value="15" />
    </attr>
    <attr name="plv_color" format="color" />

    <attr name="plv_icon_tint_normal" format="color" />
    <attr name="plv_icon_tint_selected" format="color" />
    <attr name="plv_text_color_normal" format="color" />
    <attr name="plv_text_color_selected" format="color" />

    <attr name="plv_triangle_width" format="dimension" />
    <attr name="plv_triangle_height" format="dimension" />
    <attr name="plv_triangle_margin" format="dimension" />
    <attr name="plv_triangle_position" format="enum">
        <enum name="top" value="0" />
        <enum name="bottom" value="1" />
        <enum name="left" value="2" />
        <enum name="right" value="3" />
    </attr>
    <attr name="plv_triangle_marginType" format="enum">
        <enum name="left" value="0" />
        <enum name="right" value="1" />
        <enum name="top" value="2" />
        <enum name="bottom" value="3" />
        <enum name="center" value="4" />
        <enum name="anchor" value="5" />
    </attr>
    <attr name="plv_triangle_center" format="boolean" />
    <attr name="plv_indicate_color" format="color" />
    <attr name="plv_indicate_end_color" format="color" />
    <attr name="plv_gradient_orientation" format="enum">
        <enum name="leftRight" value="0" />
        <enum name="bottomLeftTopRight" value="1" />
        <enum name="bottomTop" value="2" />
        <enum name="bottomRightTopLeft" value="3" />
        <enum name="rightLeft" value="4" />
        <enum name="topRightBottomLeft" value="5" />
        <enum name="topBottom" value="6" />
        <enum name="topLeftBottomRight" value="7" />
    </attr>
    <attr name="plv_gradient_start_color" format="color" />
    <attr name="plv_gradient_middle_color" format="color" />
    <attr name="plv_gradient_end_color" format="color" />
    <attr name="plv_gradient_colors" format="string" />

    <declare-styleable name="PLVMediaPlayerProgressSeekBar">
        <attr name="plv_seek_bar_height" format="dimension" />
        <attr name="plv_seek_bar_height_on_drag" format="dimension" />
        <attr name="plv_progress_drawable_on_drag" format="reference" />
        <attr name="plv_thumb_drawable_on_drag" format="reference" />
    </declare-styleable>

    <declare-styleable name="PLVMediaPlayerMoreLayoutAudioModeActionView">
        <attr name="plv_icon_tint_normal" />
        <attr name="plv_icon_tint_selected" />
        <attr name="plv_text_color_normal" />
        <attr name="plv_text_color_selected" />
    </declare-styleable>
    <declare-styleable name="PLVMediaPlayerMoreLayoutFloatWindowActionView">
        <attr name="plv_icon_tint_normal" />
        <attr name="plv_icon_tint_selected" />
        <attr name="plv_text_color_normal" />
        <attr name="plv_text_color_selected" />
    </declare-styleable>
    <declare-styleable name="PLVMediaPlayerMoreLayoutDownloadActionView">
        <attr name="plv_icon_tint_normal" />
        <attr name="plv_text_color_normal" />
    </declare-styleable>
    <declare-styleable name="PLVRoundRectConstraintLayout">
        <attr name="plv_radius" />
        <attr name="plv_mode" />
    </declare-styleable>
    <declare-styleable name="PLVMediaPlayerControllerGradientMaskLayout">
        <attr name="plv_top_mask_height" format="dimension" />
        <attr name="plv_bottom_mask_height" format="dimension" />
    </declare-styleable>
    <declare-styleable name="PLVTriangleIndicateLayout">
        <attr name="plv_triangle_width" />
        <attr name="plv_triangle_height" />
        <attr name="plv_triangle_margin" />
        <attr name="plv_triangle_position" />
        <attr name="plv_triangle_marginType" />
        <attr name="plv_indicate_color" />
        <attr name="plv_gradient_colors" />
        <attr name="plv_gradient_orientation" />
        <attr name="plv_radius" />
    </declare-styleable>
    <declare-styleable name="PLVMediaPlayerDanmuColorView">
        <attr name="plv_color" />
    </declare-styleable>
    <declare-styleable name="PLVMediaPlayerGestureHandleLayout">
        <attr name="plv_brightness_gesture_enable" format="boolean" />
        <attr name="plv_volume_gesture_enable" format="boolean" />
        <attr name="plv_horizon_drag_gesture_enable" format="boolean" />
        <attr name="plv_long_press_gesture_enable" format="boolean" />
        <attr name="plv_translation_gesture_enable" format="boolean" />
    </declare-styleable>
</resources>